# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — بوت إدارة نقاط المشرفين
# ─────────────────────────────────────────────────────────────────────────────

# ─── إعدادات البوت السرية ─────────────────────────────────────────────────────
config.js

# ─── قاعدة البيانات ───────────────────────────────────────────────────────────
data/

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── بيئة التشغيل ────────────────────────────────────────────────────────────
.env
.env.local
.env.production

# ─── أنظمة التشغيل ───────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Linux
*~

# ─── المحررات ────────────────────────────────────────────────────────────────

# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo

# ─── السجلات ─────────────────────────────────────────────────────────────────
logs/
*.log

# ─── ملفات مؤقتة ─────────────────────────────────────────────────────────────
tmp/
temp/
.cache/
